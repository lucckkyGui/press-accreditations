# Browser-exposed Vite variables. Only VITE_* variables are bundled into the frontend.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
PUBLIC_APP_URL=https://your-production-domain.example
ALLOWED_ORIGINS=https://your-production-domain.example,https://your-staging-domain.example

# Server-only Supabase Edge Function secrets. Do not expose these to Vite or commit real values.
# Configure these with:
# supabase secrets set KEY=value
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
STRIPE_SECRET_KEY=sk_test_or_live_value
STRIPE_WEBHOOK_SECRET=whsec_value
RESEND_API_KEY=re_value
